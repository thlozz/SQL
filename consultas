SELECT 
    departamentos.nome_depto, 
    COUNT(funcionarios.id_func) as total,
    AVG(funcionarios.salario) as media
FROM funcionarios
INNER JOIN departamentos ON funcionarios.id_depto = departamentos.id_depto
WHERE funcionarios.status_ativo = 1
GROUP BY departamentos.nome_depto;

