-- Relatório: Média salarial e contagem por departamento
SELECT 
    d.nome_depto, 
    COUNT(f.id_func) AS total_funcionarios,
    AVG(f.salario) AS media_salarial
FROM funcionarios f
INNER JOIN departamentos d ON f.id_depto = d.id_depto
WHERE f.status_ativo = TRUE
GROUP BY d.nome_depto;

